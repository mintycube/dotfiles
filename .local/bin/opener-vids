#!/bin/bash

recursive_search_dirs_vids=(~/Videos ~/win/usb1 ~/win/usb2 ~/win/usb3 ~/win/e/Library ~/Documents ~/Downloads ~/win/d/tutorials)
depth_one_dirs_vids=(~)
exclude_patterns_vids=(.git .github node_modules)

fd_command_recursive_vids="fd . -e mp4 -e avi -e mkv -e mov -e wmv -e flv -e webm -e m4v -e mpeg -e mpg -e 3gp -e rmvb -e divx -e vob -e ts -e mts"
for dir in "${recursive_search_dirs_vids[@]}"; do
	fd_command_recursive_vids+=" --full-path \"$dir\""
done
for pattern in "${exclude_patterns_vids[@]}"; do
	fd_command_recursive_vids+=" --exclude \"$pattern\""
done

fd_command_vids="fd . -e mp4 -e avi -e mkv -e mov -e wmv -e flv -e webm -e m4v -e mpeg -e mpg -e 3gp -e rmvb -e divx -e vob -e ts -e mts --max-depth 1"
for dir in "${depth_one_dirs_vids[@]}"; do
	fd_command_vids+=" --full-path \"$dir\""
done

eval "$fd_command_recursive_vids" >~/.cache/opener/vids
eval "$fd_command_vids" >>~/.cache/opener/vids
