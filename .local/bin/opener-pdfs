#!/bin/bash

recursive_search_dirs_pdfs=(~/vimwiki ~/Projects ~/win/usb1 ~/win/usb2 ~/win/usb3 ~/win/e/Library ~/Documents ~/Downloads ~/win/d/tutorials)
depth_one_dirs_pdfs=(~)
exclude_patterns_pdfs=(.git .github node_modules)

fd_command_recursive_pdfs="fd . -e pdf -e epub -e djvu"
for dir in "${recursive_search_dirs_pdfs[@]}"; do
	fd_command_recursive_pdfs+=" --full-path \"$dir\""
done
for pattern in "${exclude_patterns_pdfs[@]}"; do
	fd_command_recursive_pdfs+=" --exclude \"$pattern\""
done

fd_command_pdfs="fd . -e pdf -e epub -e djvu --max-depth 1"
for dir in "${depth_one_dirs_pdfs[@]}"; do
	fd_command_pdfs+=" --full-path \"$dir\""
done

eval "$fd_command_recursive_pdfs" >~/.cache/opener/pdfs
eval "$fd_command_pdfs" >>~/.cache/opener/pdfs
