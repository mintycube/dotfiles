#!/bin/sh

search_dir="${1:-.}"
preview='bat --style=header,numbers --color=always {}'

fd_command="fd . \
  --type file \
  --hidden \
  --follow \
  --exclude .git \
  --full-path \"$search_dir\""

fzf_command="fzf \
  --height=80% \
  --layout=reverse \
  --multi \
  --preview=\"[[ -n {1} ]] && $preview\" \
  --info=inline \
  --scroll-off=5 \
  --scrollbar='▐' \
  --ellipsis='…' \
  --marker='❱' \
  --pointer='❱'"

selected=$(eval "$fd_command" | eval "$fzf_command")

if [ -n "$selected" ]; then
	echo "$selected" | xargs "$EDITOR"
fi
