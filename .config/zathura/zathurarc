set notification-error-bg       "#EE6D85"
set notification-error-fg       "#11121D"
set notification-warning-bg     "#EE6D85"
set notification-warning-fg     "#11121D"
set notification-bg             "#E5C07B"
set notification-fg             "#11121D"

set completion-bg               "#11121D"
set completion-fg               "#98C379"
set completion-group-bg         "#11121D"
set completion-group-fg         "#E5C07b"
set completion-highlight-bg     "#E5C07b"
set completion-highlight-fg     "#11121D"

set index-bg                    "#11121D"
set index-fg                    "#A0A8CD"
set index-active-bg             "#11121D"
set index-active-fg             "#E5C07b"

set inputbar-bg                 "#11121D"
set inputbar-fg                 "#A0A8CD"
set statusbar-bg                "#11121D"
set statusbar-fg                "#A0A8CD"

set highlight-color             "#E5C07b"
set highlight-active-color      "#EE6d85"

set default-bg                  "#11121D"
set default-fg                  "#A0A8CD"

set render-loading-fg           "#A0A8CD"
set render-loading-bg           "#11121D"

set recolor-lightcolor          "#11121D"
set recolor-darkcolor           "#A0A8CD"

set statusbar-h-padding         0
set statusbar-v-padding         0
set page-padding                1
set selection-clipboard         clipboard
set adjust-open                 width
set recolor                     false
set recolor-keephue             true
set render-loading              true

map   u   scroll half-up
map   d   scroll half-down
map   D   toggle_page_mode
map   r   reload
map   R   rotate
map   K   zoom in
map   J   zoom out
map   i   recolor
map   p   print
map   g   goto top
